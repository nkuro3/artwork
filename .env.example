# 環境変数の正（ADR D11）。機密は api Worker に集約する。
# - ローカル: apps/api/.dev.vars（gitignore 済み） / apps/web/.env.local
# - 本番: api は `wrangler secret put <NAME>`、web は Cloudflare の環境変数
# Stripe 系は正式版（02-payments）で使用。プロトタイプでは不要。

# ── api Worker ──────────────────────────────────────────────
# Database (Neon) — neon-http。dev はブランチの接続文字列を使う
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Better Auth — SECRET は `openssl rand -base64 32` で生成
# URL は認証をマウントするオリジン（ローカルは api の :8787、本番は同一オリジンのサイト URL）
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:8787

# Cloudflare R2 (S3 API / presigned PUT 発行用、ADR D10)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=artwork-images

# 画像配信のベース URL（R2 カスタムドメイン、ADR D9）
# 配信は `${IMAGE_BASE_URL}/cdn-cgi/image/width=.../<r2_key>`
IMAGE_BASE_URL=https://images.example.com

# ── web (Next.js) ───────────────────────────────────────────
# api のベース URL。ローカルは別ポート、本番は同一オリジン（ADR D4）なので空 or "/"
API_URL=http://localhost:8787

# ── 正式版（02-payments）で使用。プロトタイプでは未設定で可 ──
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
